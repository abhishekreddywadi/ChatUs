// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ============================================
// PRISMA SCHEMA CONFIGURATION
// ============================================
// This file defines our database models for the Chess Game application.
// We use PostgreSQL as our database provider.

// Generator: Creates the Prisma Client that we'll use in our code
// The output path is relative to the schema file location (db/prisma/schema.prisma)
// To get to src/generated/prisma, we go up two levels (../..) then into src
generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma"
}

// ============================================
// DATASOURCE CONFIGURATION
// ============================================
// In Prisma 6 and earlier, we define the database URL directly in the schema
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// DATABASE MODELS
// ============================================

// User Model: Represents a player/user in our system
// Each user can participate in multiple games
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // In production, this should be hashed (bcrypt)

  // Relations: A user can be in multiple games as a player
  games     GamePlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Game Model: Represents a chess game session
// Contains the current state, whose turn it is, and game status
model Game {
  id          Int      @id @default(autoincrement())

  // Game state
  status      String   // waiting | ongoing | finished | abandoned
  currentFen  String   @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1") // Starting FEN position
  turn        String   @default("white") // "white" | "black"

  // Game result (nullable until game ends)
  winnerId    Int?     // References User.id if there's a winner

  // Relations
  players     GamePlayer[]  // The two players in this game
  moves       Move[]        // All moves made in this game

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// GamePlayer Model: Junction table connecting Users and Games
// This allows us to track which color each player plays
model GamePlayer {
  id     Int  @id @default(autoincrement())

  // Foreign Keys & Relations
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId Int

  // Which color this player is playing
  color  String   // "white" | "black"

  // Ensure each game has exactly 2 players with different colors
  @@unique([gameId, color])
  @@index([gameId])
  @@index([userId])
}

// Move Model: Records each move made in a game
// Useful for game replay, analysis, and move history
model Move {
  id         Int      @id @default(autoincrement())

  // Foreign Keys & Relations
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId     Int

  // Move details
  moveNumber Int      // 1,2,3... (nth move of the game)
  from       String   // "e2" (source square in algebraic notation)
  to         String   // "e4" (destination square)
  piece      String   // "P", "N", "B", "R", "Q", "K" (piece that moved)

  // Board state after this move
  fen        String   // FEN representation of board AFTER this move

  // Metadata
  createdAt  DateTime @default(now())

  @@index([gameId])
}
